# =========================================================================
# FILE CẤU HÌNH MÔI TRƯỜNG DÀNH CHO DEPLOYMENT (PRODUCTION)
# Hướng dẫn: Đổi tên file này thành `.env` trước khi khởi chạy docker-compose
# =========================================================================

# ======= BACKEND CONFIGURATION =======

# Port hiển thị của Backend trên máy chủ (Mặc định: 8080)
BACKEND_PORT=8080

# Chuỗi kết nối MongoDB
# Nếu dùng container mặc định: mongodb://mongodb:27017/ct240_task_db
# Nếu dùng MongoDB Atlas (Cloud): mongodb+srv://<username>:<password>@cluster.mongodb.net/ct240_task_db
SPRING_MONGODB_URI=mongodb://mongodb:27017/ct240_task_db

# Khóa bí mật dùng để mã hóa token JWT (Cực kỳ quan trọng, phải đổi trên Production)
JWT_SECRET=super-secret-production-key-at-least-256-bits-long

# Thời gian sống của JWT tính bằng mili-giây (Mặc định: 86400000 = 24 giờ)
JWT_EXPIRATION=86400000

# Danh sách các tên miền (CORS) được phép gọi API (Ví dụ: https://my-frontend.vercel.app)
# Dùng dấu phẩy để phân cách nhiều domain, hoặc dùng * để cho phép tất cả
ALLOWED_ORIGINS=http://localhost:5173

# ======= FRONTEND CONFIGURATION =======

# Port hiển thị của Frontend trên máy chủ (Mặc định: 5173 hoặc 80)
FRONTEND_PORT=5173

# Đường dẫn URL tới Backend API để Frontend có thể gửi request
# Lưu ý: Khi deploy, sửa thành domain thật của Backend (Ví dụ: https://api.my-app.com/api)
VITE_API_URL=http://localhost:8080/api
